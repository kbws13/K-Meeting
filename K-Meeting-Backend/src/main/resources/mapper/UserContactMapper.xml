<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.kbws.mapper.UserContactMapper">

    <!-- 基础结果映射（双主键） -->
    <resultMap id="BaseResultMap" type="xyz.kbws.model.entity.UserContact">
        <id property="userId"         column="userId"/>
        <id property="contactId"      column="contactId"/>
        <result property="status"         column="status"/>
        <result property="lastUpdateTime" column="lastUpdateTime"/>
    </resultMap>

    <!-- ContactVO 结果映射 -->
    <resultMap id="ContactVOResultMap" type="xyz.kbws.model.vo.ContactVO">
        <id property="userId"         column="userId"/>
        <id property="contactId"      column="contactId"/>
        <result property="status"         column="status"/>
        <result property="lastUpdateTime" column="lastUpdateTime"/>
        <result property="email"          column="email"/>
        <result property="nickName"       column="nickName"/>
        <result property="sex"            column="sex"/>
        <result property="userStatus"     column="userStatus"/>
        <result property="meetingNo"      column="meetingNo"/>
        <result property="lastLoginTime"  column="lastLoginTime"/>
        <result property="lastOffTime"    column="lastOffTime"/>
    </resultMap>

    <!-- 基础列名（带表别名） -->
    <sql id="Base_Column_List">
        uc.userId, uc.contactId, uc.status, uc.lastUpdateTime
    </sql>

    <!-- 查询条件片段 -->
    <sql id="query_condition">
        <where>
            <if test="query.userId != null">
                and uc.userId = #{query.userId}
            </if>
            <if test="query.status != null">
                and uc.status = #{query.status}
            </if>
        </where>
    </sql>

    <!-- 动态列表查询 SQL 片段 -->
    <sql id="query_sql">
        select
        <include refid="Base_Column_List"/>
        <if test="query.queryUserInfo != null and query.queryUserInfo">
            ,u.email         email
            ,u.nickName      nickName
            ,u.sex           sex
            ,u.status        userStatus
            ,u.meetingNo     meetingNo
            ,u.lastLoginTime lastLoginTime
            ,u.lastOffTime   lastOffTime
        </if>
        from userContact uc
        <if test="query.queryUserInfo != null and query.queryUserInfo">
            left join user u on u.id = uc.contactId
        </if>
        <include refid="query_condition"/>
        order by uc.lastUpdateTime desc
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="xyz.kbws.model.entity.UserContact">
        INSERT INTO userContact (userId, contactId, status, lastUpdateTime)
        VALUES (#{userId}, #{contactId}, #{status}, #{lastUpdateTime})
    </insert>

    <!-- 根据双主键查询 -->
    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM userContact uc
        WHERE uc.userId = #{userId} AND uc.contactId = #{contactId}
    </select>

    <!-- 查询某用户的所有联系人 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM userContact uc
        WHERE uc.userId = #{userId}
        ORDER BY uc.lastUpdateTime DESC
    </select>

    <!-- 根据双主键更新 -->
    <update id="updateByPrimaryKey" parameterType="xyz.kbws.model.entity.UserContact">
        UPDATE userContact
        <set>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="lastUpdateTime != null">
                lastUpdateTime = #{lastUpdateTime},
            </if>
        </set>
        WHERE userId = #{userId} AND contactId = #{contactId}
    </update>

    <!-- 根据双主键删除 -->
    <delete id="deleteByPrimaryKey">
        DELETE FROM userContact
        WHERE userId = #{userId} AND contactId = #{contactId}
    </delete>

    <!-- 分页查询联系人列表 -->
    <select id="findListByPage" resultMap="ContactVOResultMap">
        <include refid="query_sql"/>
    </select>
</mapper>
